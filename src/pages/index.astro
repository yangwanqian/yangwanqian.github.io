---
import BaseLayout from '../layouts/BaseLayout.astro';
import PublicationCard from '../components/PublicationCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { profile } from '../data/profile';
import { getCollection } from 'astro:content';

const publications = (await getCollection('publications'))
  .filter((item) => item.data.selected)
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 3);

const projects = (await getCollection('projects'))
  .filter((item) => item.data.featured)
  .slice(0, 3);

const news = (await getCollection('news'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);
---

<BaseLayout>
  <section class="hero">
    <img class="avatar" src={profile.avatar} alt={`${profile.name} portrait`} />
    <div>
      <p class="eyebrow">{profile.title} · {profile.affiliation}</p>
      <h1>{profile.name}</h1>
      <p class="subtitle">{profile.bio}</p>
      <div class="actions">
        <a class="button" href="/publications/">View Publications</a>
        <a class="button secondary" href={`mailto:${profile.email}`}>Contact</a>
      </div>
    </div>
  </section>

  <section class="section">
    <h2>Research Interests</h2>
    <div class="tag-list">
      {profile.researchInterests.map((item) => <span class="tag">{item}</span>)}
    </div>
  </section>

  <section class="section">
    <h2>Selected Publications</h2>
    <div class="list">
      {publications.map((publication) => <PublicationCard publication={publication} />)}
    </div>
  </section>

  <section class="section">
    <h2>Featured Projects</h2>
    <div class="grid">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class="section">
    <h2>News</h2>
    <div class="list">
      {news.map((item) => (
        <article class="card">
          <h3>{item.data.title}</h3>
          <div class="meta"><span>{item.data.date.toISOString().slice(0, 10)}</span></div>
          <p>{item.data.summary}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
